pipeline {
    agent any
    tools {
        nodejs 'nodejs'  // Nom que tu as configuré dans Global Tool Configuration
    }
    stages {
        stage('Install') {
            steps {
                bat 'npm install'
            }
        }
        stage('Test') {
            steps {
                bat 'npm test'
            }
        }
        stage('Build') {
            steps {
                bat 'node serveur.js'
            }
        }
    }
    post {
        success {
            echo 'Bravo, déploiement réussi !'
        }
    }
}